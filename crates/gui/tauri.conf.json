{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenAPI Validator",
  "identifier": "org.entur.oav",
  "build": {
    "beforeDevCommand": { "script": "npm run dev", "cwd": "./frontend" },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": { "script": "npm run build", "cwd": "./frontend" },
    "frontendDist": "./frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenAPI Validator",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
